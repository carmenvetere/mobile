# Home Assistant secrets — never commit real credentials.
secrets.yaml
.jwt_secret
*.pem
*.key
.cloud/

# Local/runtime artifacts that should not be version-controlled.
*.db
*.db-shm
*.db-wal
*.log
*.sql
.storage/
.cache/
.exports
.timeline
.vacuum
.ha_run.lock
home-assistant.log*
.HA_VERSION

# Folders to exclude.
# NOTE: ignore rules only affect files git is not already tracking. If
# something listed here shows up tracked, it was committed before the rule
# existed — untrack it with `git rm --cached <path>`.
# Intentionally TRACKED (so not listed): esphome/ and blueprints/ hold
# sanitized configs (device secrets live in git-ignored esphome/secrets.yaml);
# config/www/ holds media referenced by automations.
/www/
/custom_components/
/config/llmvision/
/image/
/llmvision/
/lovelace/
/media/
/model_cache/
/solcast_solar/
/timelapese/
/tts/

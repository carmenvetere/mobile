# Home Assistant secrets — never commit real credentials.
secrets.yaml
.jwt_secret
*.pem
*.key
.cloud/

# Local/runtime artifacts that should not be version-controlled.
*.db
*.db-shm
*.db-wal
*.log
*.sql
.storage/
.cache/
.exports
.timeline
.vacuum
.ha_run.lock
home-assistant.log*
.HA_VERSION

# Folders to exclude
/www/
/custom_components/
/blueprints/
/config/
/esphome/
/image/
/llmvision/
/lovelace/
/media/
/model_cache/
/solcast_solar/
/timelapese/
/tts/

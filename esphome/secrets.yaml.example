# Template for esphome/secrets.yaml. Copy to esphome/secrets.yaml on the
# machine where you build ESPHome firmware (the HA box if you use the
# ESPHome add-on) and fill in real values. esphome/secrets.yaml is
# git-ignored and must never be committed.
#
# Generate a fresh API key with:  openssl rand -base64 32
# OTA and AP passwords can be any strong random string.

wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

api_key_primary_bedroom_fan: "GENERATE_ME_base64_32"
ota_password_primary_bedroom_fan: "GENERATE_ME"
ap_password_primary_bedroom_fan: "GENERATE_ME"

api_key_utility_room: "GENERATE_ME_base64_32"
ota_password_utility_room: "GENERATE_ME"
ap_password_utility_room: "GENERATE_ME"

# Archived device (not deployed); keys kept for completeness.
api_key_bedroom_bluetooth: "GENERATE_ME_base64_32"
ota_password_bedroom_bluetooth: "GENERATE_ME"
ap_password_bedroom_bluetooth: "GENERATE_ME"
